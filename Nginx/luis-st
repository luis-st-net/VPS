server {
   listen 443 ssl;
   listen [::]:443 ssl;
   
   server_name static.luis-st.net;
   
   ssl_certificate /etc/nginx/ssl/luis-st.net.cer;
   ssl_certificate_key /etc/nginx/ssl/luis-st.net.key;
   
   root /home/web/static;
   
   location = /hfu/gdp/substring {
      try_files /hfu/gdp/substring.html =404;
   }
   
   location / {
      try_files $uri $uri/ =404;
   }
}

