;
; BIND data file for local loopback interface
;
$TTL	604800
@	IN	SOA	localhost. admin.home-system.net. (
			      1		; Serial
			 604800		; Refresh
			  86400		; Retry
			2419200		; Expire
			 604800 )	; Negative Cache TTL
;
@	IN	NS	localhost.
autodiscover	IN	A	10.0.0.4
@	IN	MX	10 smtp.luis-st.net.

